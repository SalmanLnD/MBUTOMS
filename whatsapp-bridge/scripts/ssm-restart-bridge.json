{
  "commands": [
    "set -e",
    "cd /opt/MBUTOMS/whatsapp-bridge",
    "pm2 stop mbutoms-whatsapp-bridge 2>/dev/null || true",
    "pm2 delete mbutoms-whatsapp-bridge 2>/dev/null || true",
    "pkill -f 'chrome.*wwebjs_auth' 2>/dev/null || true",
    "pkill -f chromium 2>/dev/null || true",
    "sleep 5",
    "timeout 120 npm run list-groups > /tmp/mbutoms-groups.txt 2>&1 || true",
    "echo GROUP_LOOKUP",
    "grep '120363422235597898@g.us' /tmp/mbutoms-groups.txt || echo ID_NOT_FOUND",
    "pm2 start index.js --name mbutoms-whatsapp-bridge",
    "pm2 save",
    "sleep 12",
    "echo PM2_LOGS",
    "pm2 logs mbutoms-whatsapp-bridge --lines 25 --nostream 2>&1 | grep -E 'Listening to group|Bridge is ready|Linked WhatsApp|Error' || true"
  ]
}
