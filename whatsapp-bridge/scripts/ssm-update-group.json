{
  "commands": [
    "set -e",
    "cd /opt/MBUTOMS/whatsapp-bridge",
    "echo CURRENT_ENV",
    "grep '^GROUP_ID=' .env || true",
    "pm2 stop mbutoms-whatsapp-bridge 2>/dev/null || true",
    "sleep 2",
    "timeout 180 npm run list-groups 2>&1 | tee /tmp/mbutoms-groups.txt || true",
    "echo GROUP_MATCH",
    "grep '120363422235597898@g.us' /tmp/mbutoms-groups.txt || echo ID_NOT_FOUND",
    "sed -i 's/^GROUP_ID=.*/GROUP_ID=120363422235597898@g.us/' .env",
    "echo UPDATED_ENV",
    "grep '^GROUP_ID=' .env",
    "pm2 start mbutoms-whatsapp-bridge 2>/dev/null || pm2 start index.js --name mbutoms-whatsapp-bridge",
    "sleep 4",
    "pm2 logs mbutoms-whatsapp-bridge --lines 15 --nostream"
  ]
}
