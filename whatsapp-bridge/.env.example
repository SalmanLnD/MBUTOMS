# MBUTOMS attendance webhook (production API)
WEBHOOK_URL=https://mbutoms-api.vercel.app/api/webhooks/whatsapp-punch

# Must exactly match WHATSAPP_WEBHOOK_SECRET set on the MBUTOMS backend
WEBHOOK_SECRET=change-me-to-a-long-random-string

# The punch-in WhatsApp group. Run `npm run list-groups` once to find the id.
# Prefer GROUP_ID (stable). GROUP_NAME is a fallback and breaks if renamed.
GROUP_ID=
GROUP_NAME=

# How to pull the OIF from the message caption.
# Default matches: "OIF 12345", "OIF-12345", "oif: 12345/AB"
OIF_REGEX=\bOIF[\s:_-]*([A-Za-z0-9/-]+)\b

# Set to true to also read the OIF from inside the image via OCR
# (slower, less reliable, requires the optional tesseract.js dependency).
ENABLE_OCR=false

# Reliability (optional — defaults shown)
# RECONNECT_MIN_MS=15000
# RECONNECT_MAX_MS=300000
# WATCHDOG_INTERVAL_MS=300000
# WATCHDOG_PUNCH_IDLE_MS=7200000
# PUNCH_WATCH_TZ=Asia/Kolkata
# PUNCH_WATCH_START=06:30
# PUNCH_WATCH_END=11:00
# PROCESSED_IDS_MAX=5000
