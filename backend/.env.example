PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/toms
JWT_SECRET=your_jwt_secret_change_in_production
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:5173,http://localhost:5174
# Public URL for Google Apps Script export (required for Sheets sync in production)
# API_PUBLIC_URL=https://your-toms-api.example.com
# Set to false on Vercel to skip heavy startup sync on cold starts
RUN_STARTUP_SYNC=true
