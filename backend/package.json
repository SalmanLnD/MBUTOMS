{
  "name": "toms-backend",
  "version": "1.0.0",
  "description": "Training Operations Management System - Backend",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "seed": "node utils/seedWorkbook.js",
    "seed:reference": "node utils/seedReference.js",
    "seed:idsa": "node utils/runIdsaSync.js",
    "seed:pstp": "node utils/runPstpSync.js",
    "seed:classes": "node utils/runClassMigration.js",
    "seed:lrre-v": "node scripts/verify-lrre-v-semester-timetable.js",
    "test": "node --test tests/unit/**/*.test.js",
    "verify:timetable": "node scripts/verify-timetable-integrity.js",
    "verify:display": "node scripts/verify-subject-timetable-display.js",
    "import:idsa-venues": "node scripts/import-idsa-venues.mjs",
    "import:class-venues": "node scripts/import-class-venues.mjs",
    "import:lrre-venues": "node scripts/import-lrre-venues.mjs",
    "import:pstp": "node scripts/import-pstp-timetables-venues.mjs",
    "import:venue-locations": "node scripts/apply-venue-building-mappings.mjs",
    "cleanup:pedh": "node scripts/remove-all-pedh-data.mjs",
    "seed:legacy": "node utils/seed.js",
    "parse:workbook": "node utils/parseWorkbook.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "express": "^4.21.0",
    "express-validator": "^7.2.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.7.0",
    "multer": "^1.4.5-lts.1"
  }
}
